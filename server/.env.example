PORT=3001
JWT_SECRET=replace-with-a-long-random-string

# MongoDB Atlas example:
# 1. Replace <username>, <password>, and <cluster-url>.
# 2. Keep the database name after the slash, here it is agent_search.
# 3. URL-encode special characters in your password, such as @ -> %40.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/agent_search?retryWrites=true&w=majority

# Optional: set this when your connection string does not include the target database
# or when you want to override the database name from MONGODB_URI.
MONGODB_DB_NAME=agent_search
